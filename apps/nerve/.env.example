# Vercel Postgres (pgvector enabled). Use the pooled connection string
# from the Vercel Storage tab. Prisma needs both pooled and direct.
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# Embeddings (text-embedding-3-small).
OPENAI_API_KEY=""

# Web /ask interface uses the Anthropic Messages API.
# (Required by spec — Claude Code subscription cannot authenticate a hosted web app.)
ANTHROPIC_API_KEY=""

# NextAuth.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:4400"

# Single founder credentials (no registration flow).
FOUNDER_EMAIL=""
FOUNDER_PASSWORD=""

# Supervisor read-only access. Optional — leave blank to disable
# /supervisor entirely.
SUPERVISOR_EMAIL=""
SUPERVISOR_PASSWORD=""

# Public research dashboard URL (used in metadata + share links).
NEXT_PUBLIC_RESEARCH_URL="https://nerve.salespatch.co.uk/research"

# HMAC signing secret configured on the Supabase webhook that posts
# to /api/ingest/pitch. Header expected: x-supabase-signature.
SUPABASE_WEBHOOK_SECRET=""

# Shared secret for the Claude Code `nerve-log` slash command. Posted
# verbatim in the `x-nerve-secret` header on /api/ingest/changelog.
# Set the same value in every project repo's environment so any session
# can ship its log here.
NERVE_CHANGELOG_SECRET=""
