// NERVE — founder intranet for SL-MAS.
// Single Postgres database (Vercel Postgres / Neon) with pgvector enabled.
//
// Conventions:
//  - Every table has id (cuid), createdAt, updatedAt, phaseLabel.
//  - phaseLabel is the dissertation phase that was active when the row was
//    created (denormalised from PhaseBoundary for query speed).
//  - Markdown text fields are plain TEXT — rendered client-side.
//  - Vector embeddings live in a single polymorphic Embedding table keyed
//    by sourceType + sourceId. Single-table search wins over per-source
//    UNION ALL at scale.
//  - Version-history tables append-only. Parent rows hold the current value;
//    history rows record every prior value with timestamp.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── auth ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── phase boundaries (dissertation methodology timeline) ────────────────

model PhaseBoundary {
  id                     String    @id @default(cuid())
  name                   String    @unique
  startDate              DateTime
  endDate                DateTime?
  operationalDescription String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([startDate])
}

// ─── sales intelligence ──────────────────────────────────────────────────

enum PitchOutcome {
  closed // legacy alias for closed_now (kept for back-compat)
  rejected
  follow_up
  closed_now
  closed_followup
  not_pitched
}

enum InterestLevel {
  cold
  warm
  hot
}

enum DemoReaction {
  loved
  liked
  neutral
  unimpressed
}

enum PaymentMethod {
  paid_now
  will_pay_followup
}

enum FollowupTime {
  tomorrow
  this_week
  next_week
  next_month
}

enum AgreedNextStep {
  sp_will_call
  customer_will_call
  sent_link
  scheduled_meeting
}

enum PitchQualityFlag {
  ok
  excluded
}

model PitchLog {
  id                   String           @id @default(cuid())
  date                 DateTime
  businessName         String
  businessType         String?
  sector               String?
  location             String?
  leadSource           String?
  demoVersion          String?
  outcome              PitchOutcome
  contractorId         String?
  pitchDuration        Int? // seconds, auto from iOS timer
  pitchAttemptNumber   Int              @default(1)
  // Questionnaire — required fields
  decisionMakerPresent Boolean?
  demoShown            Boolean?
  interestLevel        InterestLevel?
  consentToRecord      Boolean          @default(false)
  // Questionnaire — conditional fields
  demoReaction         DemoReaction?
  agreedPrice          Decimal?         @db.Decimal(10, 2)
  paymentMethod        PaymentMethod?
  bestFollowupTime     FollowupTime?
  agreedNextStep       AgreedNextStep?
  // Questionnaire — optional gold
  gutFeelClosePct      Int? // 0-100
  firstResponsePhrase  String?
  competitorMentioned  String?
  // Auto-captured location
  gpsLat               Float?
  gpsLng               Float?
  // Quality control — derived server-side at ingest time. Dissertation
  // queries scope to qualityFlag=ok; ops queries see everything.
  qualityFlag          PitchQualityFlag @default(ok)
  // Legacy / housekeeping
  consentFlag          Boolean          @default(false) // pre-questionnaire field; kept for back-compat
  notes                String?
  supabasePitchId      String?          @unique // idempotency key for webhook
  source               String           @default("manual") // manual | webhook | mobile-api
  phaseLabel           String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  objections PitchObjection[]

  @@index([date])
  @@index([phaseLabel])
  @@index([sector])
  @@index([outcome])
  @@index([businessType])
  @@index([contractorId])
  @@index([leadSource])
  @@index([demoVersion])
  @@index([qualityFlag])
  @@index([decisionMakerPresent])
  @@index([interestLevel])
}

model ObjectionTag {
  id        String           @id @default(cuid())
  name      String           @unique
  createdAt DateTime         @default(now())
  pitches   PitchObjection[]
}

model PitchObjection {
  pitchId     String
  objectionId String
  pitch       PitchLog     @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  objection   ObjectionTag @relation(fields: [objectionId], references: [id], onDelete: Cascade)

  @@id([pitchId, objectionId])
  @@index([objectionId])
}

// ─── operations log (4 sub-types into 1 table for unified timeline view) ─

enum OperationsLogType {
  weekly
  decision
  failure
  iteration
}

model OperationsLog {
  id          String            @id @default(cuid())
  date        DateTime
  type        OperationsLogType
  // weekly: body. decision: decision/reasoning/outcome. failure:
  // whatFailed/why/whatChanged. iteration: whatChanged/beforeState/afterState.
  body        String?
  decision    String?
  reasoning   String?
  outcome     String?
  whatFailed  String?
  why         String?
  whatChanged String?
  beforeState String?
  afterState  String?
  tags        String[]          @default([])
  phaseLabel  String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([date])
  @@index([type])
  @@index([phaseLabel])
}

// ─── financial tracker ───────────────────────────────────────────────────

enum CostCategory {
  infrastructure
  compute
  tools
  misc
}

model RevenueEntry {
  id            String   @id @default(cuid())
  date          DateTime
  dealReference String?
  amount        Decimal  @db.Decimal(12, 2)
  notes         String?
  phaseLabel    String
  createdAt     DateTime @default(now())
