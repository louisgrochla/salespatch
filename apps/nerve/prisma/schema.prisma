  updatedAt   DateTime @updatedAt
}

model GlossaryEntry {
  id         String   @id @default(cuid())
  term       String   @unique
  definition String
  context    String?
  phaseLabel String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ExternalResource {
  id         String   @id @default(cuid())
  toolName   String
  url        String
  purpose    String
  notes      String?
  phaseLabel String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── legal & compliance ──────────────────────────────────────────────────

model LegalDocument {
  id            String   @id @default(cuid())
  type          String
  title         String
  version       String
  date          DateTime
  content       String?
  fileReference String?
  phaseLabel    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GdprRecord {
  id               String   @id @default(cuid())
  dataType         String
  collectionMethod String
  retentionPeriod  String
  legalBasis       String
  phaseLabel       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ContractorAgreementVersion {
  id         String   @id @default(cuid())
  version    String   @unique
  content    String
  date       DateTime
  phaseLabel String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CompaniesHouseRecord {
  id          String   @id @default(cuid())
  filingType  String
  description String
  date        DateTime
  reference   String?
  phaseLabel  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IpDocument {
  id          String   @id @default(cuid())
  type        String   // trademark | patent | copyright | trade_secret | other
  title       String
  description String?
  date        DateTime
  reference   String?
  phaseLabel  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── /ask conversation history ──────────────────────────────────────────
//
// Each /ask query persists alongside the retrieved sources and Claude's
// response. The conversation log is itself dissertation evidence —
// "I asked the system X on date Y" is citable.

model ChatSession {
  id          String        @id @default(cuid())
  title       String?
  phaseLabel  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages    ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  // "user" | "assistant" | "system" — the system message is built fresh
  // per turn from current vault state, never persisted as a row.
  role         String
  content      String
  // Sources retrieved for THIS turn — array of
  // { sourceType, sourceId, title, excerpt, distance, sectionPath }.
  sources      Json?
  model        String?
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime    @default(now())

  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// ─── changelog (Claude Code session log) ─────────────────────────────────
//
// Each row is one development session, posted by the `nerve-log` slash
// command from Claude Code. Becomes both operational history and
// dissertation methodology evidence. See /api/ingest/changelog.

enum ChangelogProjectType {
  nerve
  salespatch
  ios_app
  sl_mas_pipeline
  spit_out
  other
}

model ChangelogEntry {
  id                     String               @id @default(cuid())
  project                String
  sessionSummary         String
  whatChanged            String
  why                    String
  decisionsMade          String
  problemsEncountered    String
  currentState           String
  whatsNext              String
  filesModified          String[]             @default([])
  sessionDate            DateTime
  sessionDurationMinutes Int?
  tags                   String[]             @default([])
  retrospectiveNote      String?
  projectType            ChangelogProjectType
  phaseLabel             String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([sessionDate])
  @@index([project])
  @@index([projectType])
  @@index([phaseLabel])
  @@index([tags], type: Gin)
}

// ─── webhook ingestion log (operational visibility for failures) ─────────

enum IngestStatus {
  ok
  failed
}

model WebhookIngestion {
  id           String       @id @default(cuid())
  endpoint     String
  status       IngestStatus
  errorMessage String?
  payloadHash  String?
  createdAt    DateTime     @default(now())

  @@index([createdAt])
  @@index([status])
}

// ─── embeddings (single polymorphic table) ───────────────────────────────
//
// Vector column is declared with Unsupported because Prisma does not have
// a native vector type. The migration SQL adds the actual vector(1536)
// column and the ivfflat index. All vector reads/writes happen via raw
// queries in src/lib/embeddings.ts.

model Embedding {
  id          String                       @id @default(cuid())
  sourceType  String                       // model name, e.g. "PitchLog"
  sourceId    String
  chunkText   String
  chunkIndex  Int                          @default(0)
  metadata    Json
  embedding   Unsupported("vector(1536)")?
  phaseLabel  String
  createdAt   DateTime                     @default(now())

  @@index([sourceType, sourceId])
  @@index([phaseLabel])
  @@index([sourceType])
}
