}

model PromptLibraryEntry {
  id               String   @id @default(cuid())
  name             String   @unique
  fullText         String // current value
  model            String
  versionNumber    Int      @default(1)
  performanceNotes String?
  tags             String[] @default([])
  phaseLabel       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  versions PromptVersion[]
}

model PromptVersion {
  id               String   @id @default(cuid())
  promptId         String
  fullText         String
  model            String
  versionNumber    Int
  performanceNotes String?
  createdAt        DateTime @default(now())

  prompt PromptLibraryEntry @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, versionNumber])
  @@index([promptId])
}

model InfrastructureNote {
  id          String   @id @default(cuid())
  serviceName String
  purpose     String
  configNotes String?
  date        DateTime
  phaseLabel  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PipelineDoc {
  id               String   @id @default(cuid())
  name             String
  description      String
  version          String
  performanceNotes String?
  phaseLabel       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ModelDoc {
  id              String   @id @default(cuid())
  name            String
  purpose         String
  trainingDetails String?
  costPerCycle    Decimal? @db.Decimal(10, 4)
  phaseLabel      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── demo library ────────────────────────────────────────────────────────

model DemoRecord {
  id                String   @id @default(cuid())
  businessName      String
  sector            String?
  url               String?
  fileReference     String?
  dateBuilt         DateTime
