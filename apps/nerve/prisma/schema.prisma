// ─── lead intelligence ───────────────────────────────────────────────────

enum ContactedStatus {
  not_contacted
  contacted
  pitched
  closed
  rejected
}

model LeadRecord {
  id              String          @id @default(cuid())
  name            String
  type            String?
  sector          String?
  location        String?
  contactedStatus ContactedStatus @default(not_contacted)
  sourceMethod    String?
  doNotContact    Boolean         @default(false)
  notes           String?
  phaseLabel      String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([sourceMethod])
  @@index([contactedStatus])
  @@index([sector])
}

// ─── research project ────────────────────────────────────────────────────

enum DissertationStatus {
  not_started
  draft
  in_progress
  complete
}

enum LiteraturePosition {
  supports
  challenges
  contextualises
}

// Single-row table — there is one dissertation. Use id = "main".
model DissertationMeta {
  id                       String             @id @default("main")
  workingTitle             String
  researchQuestion         String
  supervisor               String?
  submissionDeadline       DateTime?
  submissionDeadlineNote   String? // free text when the deadline isn't yet known
  overallStatus            DissertationStatus @default(in_progress)
  degree                   String? // e.g. "BA (Hons) Digital Marketing and Business Analytics"
  institution              String? // e.g. "Robert Gordon University, Aberdeen"
  wordCountTargetMin       Int?
  wordCountTargetMax       Int?
  // The academic framing paragraph — describes the study to a supervisor in
  // the right register. Surfaced by /ask in Stage 5 whenever the dissertation
  // topic or framing is queried.
  academicFraming          String?
  // Markdown bullet lists of how this study connects to each half of the
  // degree.
  degreeRelevanceMarketing String?
  degreeRelevanceAnalytics String?
  phaseLabel               String
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  workingTitleVersions     WorkingTitleVersion[]
  researchQuestionVersions ResearchQuestionVersion[]
}

model WorkingTitleVersion {
  id             String   @id @default(cuid())
  dissertationId String
  value          String
  createdAt      DateTime @default(now())

  dissertation DissertationMeta @relation(fields: [dissertationId], references: [id], onDelete: Cascade)

  @@index([dissertationId])
}

model ResearchQuestionVersion {
  id             String   @id @default(cuid())
  dissertationId String
  value          String
  createdAt      DateTime @default(now())

  dissertation DissertationMeta @relation(fields: [dissertationId], references: [id], onDelete: Cascade)

  @@index([dissertationId])
}

model LiteratureEntry {
  id            String              @id @default(cuid())
  title         String
  authors       String
  year          Int?
  url           String?
  doi           String?
  abstract      String?
  themeTags     String[]            @default([])
  personalNotes String?
  position      LiteraturePosition?
  phaseLabel    String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  sectionLinks DissertationSectionLiterature[]

  @@index([year])
  @@index([themeTags], type: Gin)
}

model DissertationSection {
  id                 String             @id @default(cuid())
  chapter            String             @unique
  content            String             @default("")
  status             DissertationStatus @default(not_started)
  wordCountTarget    Int?
  wordCount          Int                @default(0)
  supervisorFeedback String?
  phaseLabel         String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  versions        DissertationSectionVersion[]
  literatureLinks DissertationSectionLiterature[]
  evidenceItems   EvidenceLog[]
  calendarItems   AcademicCalendarItem[]
}

model DissertationSectionVersion {
  id        String   @id @default(cuid())
  sectionId String
  content   String
  wordCount Int
  createdAt DateTime @default(now())

  section DissertationSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model DissertationSectionLiterature {
  sectionId    String
  literatureId String
  section      DissertationSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  literature   LiteratureEntry     @relation(fields: [literatureId], references: [id], onDelete: Cascade)

  @@id([sectionId, literatureId])
  @@index([literatureId])
}

model MethodologyDoc {
  id                        String   @id @default(cuid())
  phaseName                 String   @unique
  formalDescription         String
  mixedMethodsJustification String?
  sampleSizeNotes           String?
  statisticalApproach       String?
  gdprHandling              String?
  nerveAsInfrastructure     String?
  phaseLabel                String
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// Polymorphic — sourceType refers to a model name (e.g. "PitchLog").
model EvidenceLog {
  id                    String   @id @default(cuid())
  sourceType            String
  sourceId              String
  dissertationSectionId String?
  annotation            String
  phaseLabel            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  dissertationSection DissertationSection? @relation(fields: [dissertationSectionId], references: [id], onDelete: SetNull)

  @@index([sourceType, sourceId])
  @@index([dissertationSectionId])
}

model SupervisorMeeting {
  id             String   @id @default(cuid())
  date           DateTime
  notes          String?
  feedback       String?
  agreedActions  String?
  followUpStatus String?
  phaseLabel     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

model AcademicCalendarItem {
  id                    String   @id @default(cuid())
  milestone             String
  deadline              DateTime
  status                String   @default("pending")
  dissertationSectionId String?
  phaseLabel            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  dissertationSection DissertationSection? @relation(fields: [dissertationSectionId], references: [id], onDelete: SetNull)

  @@index([deadline])
}

