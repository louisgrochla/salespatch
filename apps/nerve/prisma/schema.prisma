model CostEntry {
  id         String       @id @default(cuid())
  date       DateTime
  category   CostCategory
  amount     Decimal      @db.Decimal(12, 2)
  notes      String?
  phaseLabel String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([date])
  @@index([phaseLabel])
  @@index([category])
}

