// ─── /ask conversation history ──────────────────────────────────────────
//
// Each /ask query persists alongside the retrieved sources and Claude's
// response. The conversation log is itself dissertation evidence —
// "I asked the system X on date Y" is citable.

model ChatSession {
  id         String   @id @default(cuid())
  title      String?
  phaseLabel String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages ChatMessage[]

  @@index([createdAt])
}

model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  // "user" | "assistant" | "system" — the system message is built fresh
  // per turn from current vault state, never persisted as a row.
  role         String
  content      String
  // Sources retrieved for THIS turn — array of
  // { sourceType, sourceId, title, excerpt, distance, sectionPath }.
  sources      Json?
  model        String?
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// ─── changelog (Claude Code session log) ─────────────────────────────────
//
// Each row is one development session, posted by the `nerve-log` slash
// command from Claude Code. Becomes both operational history and
// dissertation methodology evidence. See /api/ingest/changelog.

enum ChangelogProjectType {
  nerve
  salespatch
  ios_app
  sl_mas_pipeline
  spit_out
  other
}

model ChangelogEntry {
  id                     String               @id @default(cuid())
  project                String
  sessionSummary         String
  whatChanged            String
  why                    String
  decisionsMade          String
  problemsEncountered    String
  currentState           String
  whatsNext              String
  filesModified          String[]             @default([])
  sessionDate            DateTime
  sessionDurationMinutes Int?
  tags                   String[]             @default([])
  retrospectiveNote      String?
  projectType            ChangelogProjectType
  phaseLabel             String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([sessionDate])
  @@index([project])
  @@index([projectType])
  @@index([phaseLabel])
  @@index([tags], type: Gin)
}

// ─── webhook ingestion log (operational visibility for failures) ─────────

enum IngestStatus {
  ok
  failed
}

model WebhookIngestion {
  id           String       @id @default(cuid())
  endpoint     String
  status       IngestStatus
  errorMessage String?
  payloadHash  String?
  createdAt    DateTime     @default(now())

  @@index([createdAt])
  @@index([status])
}

// ─── embeddings (single polymorphic table) ───────────────────────────────
//
// Vector column is declared with Unsupported because Prisma does not have
// a native vector type. The migration SQL adds the actual vector(1536)
// column and the ivfflat index. All vector reads/writes happen via raw
// queries in src/lib/embeddings.ts.

model Embedding {
  id         String                       @id @default(cuid())
  sourceType String // model name, e.g. "PitchLog"
  sourceId   String
  chunkText  String
  chunkIndex Int                          @default(0)
  metadata   Json
  embedding  Unsupported("vector(1536)")?
  phaseLabel String
  createdAt  DateTime                     @default(now())

  @@index([sourceType, sourceId])
  @@index([phaseLabel])
  @@index([sourceType])
}

// ─── SL-MAS pipeline learning ────────────────────────────────────────────
//
// Mirrors the better-sqlite3 schemas in src/learning/decisionStore.ts,
// src/memory/episodicStore.ts, src/memory/strategicStore.ts,
// src/runtime/modelRegistry.ts on the runtime side. Migrated to Postgres
// so the SL-MAS data layer co-locates with NERVE — collapses the Pi-as-
// data-host hop and lets pitch outcome ingest write atomically alongside
// PitchLog upsert.
//
// Naming: snake_case in DB via @map() so existing SQL queries written
// against the runtime tables (smoke scripts, ad-hoc psql) translate
// cleanly; Prisma client uses camelCase as is house style.

model Decision {
  id            String   @id @default(cuid())
  agentId       String   @map("agent_id")
  runId         String   @map("run_id")
  nodeId        String   @map("node_id")
  action        String
  reasoning     String
  alternatives  Json // JSON array of strings
  confidence    Float
  inputsSummary String   @map("inputs_summary")
  outputSummary String   @map("output_summary")
  tags          String[] // Postgres native array; runtime side uses tags_json TEXT
  createdAt     DateTime @default(now()) @map("created_at")

  outcomes Outcome[]

  @@index([agentId, createdAt(sort: Desc)])
  @@index([runId, createdAt(sort: Asc)])
  @@index([tags], type: Gin)
  @@map("decisions")
}

model Outcome {
  id                   String   @id @default(cuid())
  decisionId           String   @map("decision_id")
  outcomeType          String   @map("outcome_type")
  result               String // "positive" | "negative" | "neutral"
  metricValue          Float?   @map("metric_value")
  metricName           String?  @map("metric_name")
  notes                String
  lagHours             Float?   @map("lag_hours")
  recordedAt           DateTime @default(now()) @map("recorded_at")
  // Attribution columns (populated by AttributionEngine after ingest)
  attributionWeight    Float?   @map("attribution_weight")
  attributionReasoning String?  @map("attribution_reasoning")

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId])
  @@index([recordedAt(sort: Desc)])
  @@map("outcomes")
}

model LearningInsight {
  id             String   @id @default(cuid())
  agentId        String   @map("agent_id")
  pattern        String
  sampleSize     Int      @map("sample_size")
  avgMetric      Float?   @map("avg_metric")
  recommendation String
  generatedAt    DateTime @default(now()) @map("generated_at")

  @@index([agentId, generatedAt(sort: Desc)])
  @@map("learning_insights")
}

model OutcomeIngestLog {
  // externalId is the idempotency key — NERVE pitchLog.id, Supabase
  // assignment_id:status, or build-demo slug:ts. Kept as the primary key
  // (not a generated cuid) so duplicate ingests are caught at INSERT time.
  externalId       String   @id @map("external_id")
  source           String // "nerve_webhook" | "supabase_poll" | "manual_skill" | "test"
  payload          Json // OutcomeIngestPayload
  matchedDecisions Int      @map("matched_decisions")
  matchStrategy    String   @map("match_strategy") // "lead_id" | "business_name_date" | "none"
  episodeId        String?  @map("episode_id")
  ingestedAt       DateTime @default(now()) @map("ingested_at")

  @@index([source, ingestedAt(sort: Desc)])
  @@map("outcome_ingest_log")
}

model SlMasKv {
  // Renamed from `kv` to avoid namespace collision with anything NERVE
  // might later add. Used by SupabaseOutcomePoller cursor and similar
  // bookkeeping. Tiny table.
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("sl_mas_kv")
}

model Episode {
  id                    String    @id @default(cuid())
  pipelineRunId         String    @unique @map("pipeline_run_id")
  pipelineDefinitionId  String    @map("pipeline_definition_id")
  trigger               String?
  leadId                String?   @map("lead_id")
  businessName          String?   @map("business_name")
  vertical              String?
  region                String?
  startedAt             DateTime  @map("started_at")
  endedAt               DateTime? @map("ended_at")
  status                String // "running" | "completed" | "failed" | "blocked" | "cancelled"
  totalCostUsd          Float     @default(0) @map("total_cost_usd")
  reflectionIterations  Int       @default(0) @map("reflection_iterations")
  agentOutputsSummary   Json      @map("agent_outputs_summary") // node_id -> summary string
  criticScores          Json      @map("critic_scores") // node_id -> score
  workingMemorySnapshot Json      @map("working_memory_snapshot")
  strategiesUsed        String[]  @map("strategies_used")
  pivotTags             String[]  @map("pivot_tags")
  // Outcome (filled later)
  pitchOutcome          String?   @map("pitch_outcome") // "closed" | "rejected" | "follow_up" | "no_outcome"
  outcomeReceivedAt     DateTime? @map("outcome_received_at")
  closeAmountGbp        Float?    @map("close_amount_gbp")
  daysToOutcome         Float?    @map("days_to_outcome")
  outcomeNotes          String?   @map("outcome_notes")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@index([leadId, startedAt(sort: Desc)])
  @@index([pitchOutcome, startedAt(sort: Desc)])
  @@index([vertical, startedAt(sort: Desc)])
  @@index([pivotTags], type: Gin)
  @@map("episodes")
}

model Strategy {
  id              String    @id @default(cuid())
  vertical        String
  region          String?
  strategyType    String    @map("strategy_type")
  parameters      Json // design_combination params (hero, palette, cta, ...)
  sampleSize      Int       @default(0) @map("sample_size")
  closeRate       Float?    @map("close_rate")
  confidenceLower Float?    @map("confidence_lower")
  confidenceUpper Float?    @map("confidence_upper")
  status          String    @default("new") // "new"|"testing"|"active"|"champion"|"deprecated"
  lastEvaluatedAt DateTime? @map("last_evaluated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([vertical, status, closeRate(sort: Desc)])
  // Note: uniqueness on (vertical, region, parameters) is enforced in the
  // StrategicStore layer via findFirst; Prisma can't put a unique constraint
  // directly on a Json column without a generated stable hash.
  @@map("strategies")
}

model ModelRegistration {
  id          String   @id @default(cuid())
  kind        String // "critic" | "agent"
  agentId     String?  @map("agent_id") // null = global slot
  version     String
  source      String // "heuristic" | "llm" | "lora" | "external"
  endpoint    String?
  weightsPath String?  @map("weights_path")
  active      Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([kind, agentId, active])
  @@map("model_registrations")
}


// ─── lead profile snapshots ──────────────────────────────────────────────
//
// Rich enriched-data snapshots produced by the Pi `lead-profiler-agent` or
// the manual `/build-demo` spec-site research workflow. Distinct from
// LeadRecord (the simpler founder-facing record) — this row is the
// AI-introspectable corpus: Instagram numbers, review summaries, services,
// qualifier verdicts, raw scout/profiler payloads. One row per lead, keyed
// on the natural slug `lead_id`. Re-profiling upserts in place so a Pi
// rerun replaces the previous snapshot rather than accreting duplicates.
//
// `raw_scout_data` and `raw_profiler_data` are kept for audit so future
// agents can re-derive structured fields without re-scraping.

model LeadProfile {
  id                   String   @id @default(cuid())
  leadId               String   @unique @map("lead_id") // natural key (slug)
  businessName         String   @map("business_name")
  businessType         String?  @map("business_type")
  vertical             String?
  category             String? // e.g. "barber" specifically vs "health" generically
  address              String?
  postcode             String?
  phone                String?
  email                String?
  websiteUrl           String?  @map("website_url")
  websiteQualityScore  Int?     @map("website_quality_score") // 0-100
  googleRating         Float?   @map("google_rating")
  googleReviewCount    Int?     @map("google_review_count")
  bestReviews          Json?    @map("best_reviews") // [{ author, rating, text, date }]
  instagramHandle      String?  @map("instagram_handle")
  instagramFollowers   Int?     @map("instagram_followers")
  instagramPostCount   Int?     @map("instagram_post_count")
  instagramBio         String?  @map("instagram_bio")
  photoCount           Int      @default(0) @map("photo_count")
  hasLogo              Boolean  @default(false) @map("has_logo")
  hasHeroImage         Boolean  @default(false) @map("has_hero_image")
  openingHours         String[] @default([]) @map("opening_hours")
  services             Json? // [{ name, description, isScraped }]
  priceRange           String?  @map("price_range")
  qualificationScore   Float?   @map("qualification_score") // 0-1
  qualificationReasons String[] @default([]) @map("qualification_reasons")
  qualifierVerdict     String?  @map("qualifier_verdict") // "qualified" | "rejected" | "uncertain"
  latitude             Float?
  longitude            Float?
  rawScoutData         Json?    @map("raw_scout_data") // original Google Places response
  rawProfilerData      Json?    @map("raw_profiler_data") // original profiler output
  metadata             Json     @default("{}")
  profiledAt           DateTime @default(now()) @map("profiled_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([vertical, profiledAt(sort: Desc)])
  @@index([qualifierVerdict, profiledAt(sort: Desc)])
  @@index([postcode])
  @@map("lead_profiles")
}

 
// ─── composer workbench iterations ───────────────────────────────────────
//
// Founder's manual demo-iteration trail from `tools/workbench/`. Every save
// (AI generate, manual edit, rename, delete) writes a row here so the
// "this is what we tried, this is what worked" history is captured outside
// the local filesystem. Inline HTML — full snapshot, not a delta. Cheap at
// the volume the founder produces (handful per lead per day) and lets the
// next /build-demo skill consult prior iterations for the same vertical.
//
// Idempotency key: `iteration_id` (caller-supplied, format
// `<lead_slug>-<iso_no_colons>`) so retries from the workbench don't double-
// insert when the network round-trip fails.

model ComposerIteration {
  id                 String   @id @default(cuid())
  iterationId        String   @unique @map("iteration_id") // <lead_slug>-<iso_no_colons>
  leadId             String?  @map("lead_id")
  businessName       String?  @map("business_name")
  vertical           String?
  htmlOutput         String   @map("html_output") // full HTML, inline
  cssOutput          String?  @map("css_output")
  prompt             String? // system + user prompt that produced this if AI-generated
  response           String? // raw AI response if applicable
  editKind           String   @map("edit_kind") // "ai_generate" | "manual_edit" | "save" | "delete" | "rename"
  editorNotes        String?  @map("editor_notes")
  parentIterationId  String?  @map("parent_iteration_id")
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([leadId, createdAt(sort: Desc)])
  @@index([editKind, createdAt(sort: Desc)])
  @@index([parentIterationId])
  @@map("composer_iterations")
}

// Per-call API spend ledger. Each successful (or failed) outbound call to a
// paid external API — OpenRouter, Apify, Google Places, etc. — writes one
// row. Lets the founder answer "how much did vertical=barber cost in
// May?" from a single query without scraping provider dashboards.
//
// Written by the Pi runtime via fire-and-forget POST to
// /api/ingest/spend (see src/lib/spendReporter.ts on the runtime side).
model SpendLedger {
  id            String   @id @default(cuid())
  provider      String // "openrouter" | "apify" | "google_places" | other
  model         String? // e.g. "anthropic/claude-sonnet-4-20250514"
  agentId       String?  @map("agent_id") // e.g. "site-composer-agent"
  runId         String?  @map("run_id") // pipeline run ID when known
  nodeId        String?  @map("node_id") // pipeline node ID when known
  leadId        String?  @map("lead_id") // lead slug when known
  vertical      String? // "barber" | "cafe" | etc.
  costUsd       Float    @map("cost_usd") // non-zero, in USD
  inputTokens   Int?     @map("input_tokens") // LLM input tokens
  outputTokens  Int?     @map("output_tokens") // LLM output tokens
  totalTokens   Int?     @map("total_tokens")
  requestKind   String?  @map("request_kind") // "completion" | "embedding" | "scrape" | "places_search" | etc.
  success       Boolean  @default(true)
  errorMessage  String?  @map("error_message") // populated on failure
  metadata      Json     @default("{}") // provider-specific (response_id, finish_reason, ...)
  occurredAt    DateTime @map("occurred_at") // when the API call happened
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([provider, occurredAt(sort: Desc)])
  @@index([agentId, occurredAt(sort: Desc)])
  @@index([leadId, occurredAt(sort: Desc)])
  @@index([runId])
  @@map("spend_ledger")
}


// ─── site briefs ─────────────────────────────────────────────────────────
//
// A2 of Phase A. The `spec-site-brief` skill (or autumn Pi
// `brief-generator-agent`) writes the full brief markdown plus structured
// fields after each /build-demo run. Caller-supplied `briefId` lets the
// skill replay safely on transient network failure. Indexed on `leadId` so
// "latest brief for X" is a single query, history preserved by ordering on
// `generatedAt` DESC.

model SiteBrief {
  id                 String   @id @default(cuid())
  briefId            String   @unique @map("brief_id") // caller-supplied natural key
  leadId             String   @map("lead_id") // slug
  businessName       String   @map("business_name")
  businessType       String?  @map("business_type")
  vertical           String?
  postcode           String?
  address            String?
  ownerName          String?  @map("owner_name")
  verdict            String // "PROCEED" | "PASS"
  verdictReason      String?  @map("verdict_reason")
  googleRating       Float?   @map("google_rating")
  googleReviewCount  Int?     @map("google_review_count")
  instagramHandle    String?  @map("instagram_handle")
  instagramFollowers Int?     @map("instagram_followers")
  yearsTrading       String?  @map("years_trading")
  awardsPress        String[] @default([]) @map("awards_press")
  diagnosis          String? // Phase 3 problem statement
  pitchAngle         String?  @map("pitch_angle") // line for the door
  testOfSuccess      String?  @map("test_of_success") // owner-recognition test
  blueprintSections  Json?    @map("blueprint_sections") // [{ name, intent }]
  briefMarkdown      String   @map("brief_markdown") // full body
  source             String   @default("manual_skill") // "manual_skill" | "pi_brief_generator"
  metadata           Json     @default("{}")
  generatedAt        DateTime @default(now()) @map("generated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([leadId, generatedAt(sort: Desc)])
  @@index([vertical, generatedAt(sort: Desc)])
  @@index([verdict])
  @@map("site_briefs")
}


// ─── brand analyses ──────────────────────────────────────────────────────
//
// Phase 2 of the spec-site-brief skill, lifted out of the markdown into
// structured JSON the AI layer can query directly (eg "show me every
// barber demo whose dominant colour was reds in the #B0-#FF range").
// Soft FK to SiteBrief.briefId so analyses without a parent brief are still
// valid (autumn Pi could emit pure brand analysis from photos alone).

model BrandAnalysis {
  id                    String   @id @default(cuid())
  analysisId            String   @unique @map("analysis_id")
  leadId                String   @map("lead_id")
  briefId               String?  @map("brief_id") // soft FK to site_briefs.briefId
  dominantHex           String?  @map("dominant_hex")
  dominantPct           Int?     @map("dominant_pct") // 0-100
  neutralHex            String?  @map("neutral_hex")
  neutralPct            Int?     @map("neutral_pct")
  accentHex             String?  @map("accent_hex")
  accentPct             Int?     @map("accent_pct")
  displayFont           String?  @map("display_font")
  displayFallback       String?  @map("display_fallback")
  bodyFont              String?  @map("body_font")
  bodyFallback          String?  @map("body_fallback")
  monoFont              String?  @map("mono_font")
  monoFallback          String?  @map("mono_fallback")
  logoDescription       String?  @map("logo_description")
  logoKind              String?  @map("logo_kind") // "clean_vector" | "hand_imperfect" | "asset_only"
  voiceAdjectives       String[] @default([]) @map("voice_adjectives")
  voiceQuotes           String[] @default([]) @map("voice_quotes") // verbatim lines
  positioningReference  String?  @map("positioning_reference")
  positioningRationale  String?  @map("positioning_rationale")
  assetNotes            String[] @default([]) @map("asset_notes")
  analysisMarkdown      String?  @map("analysis_markdown") // Phase 2 verbatim
  source                String   @default("manual_skill")
  metadata              Json     @default("{}")
  analyzedAt            DateTime @default(now()) @map("analyzed_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([leadId, analyzedAt(sort: Desc)])
  @@index([briefId])
  @@index([positioningReference])
  @@map("brand_analyses")
}


// ─── demo HTML artefacts ─────────────────────────────────────────────────
//
// A3 of Phase A. Stores every generated demo HTML inline so the artefact
// trail is replayable and queryable from NERVE without going back to the
// filesystem or Supabase Storage. Pairs with A1 (composer iterations) and
// A2 (site_briefs) — soft FKs to both let the AI layer trace
// brief → iterations → final artefact for any lead.
//
// Caller-supplied artefactId so the build-demo skill / Pi composer can
// retry on transient failure without double-inserting. Indexed on
// (leadId, generatedAt DESC) for "latest demo for X" lookups; history is
// preserved by appending new rows on each rebuild.

model DemoArtefact {
  id                    String   @id @default(cuid())
  artefactId            String   @unique @map("artefact_id") // caller-supplied natural key
  leadId                String   @map("lead_id")
  briefId               String?  @map("brief_id") // soft FK to site_briefs.briefId
  composerIterationId   String?  @map("composer_iteration_id") // soft FK to composer_iterations.iterationId
  businessName          String   @map("business_name")
  vertical              String?
  htmlInline            String   @map("html_inline") // full demo.html, base64 photos already embedded upstream
  htmlSizeBytes         Int      @map("html_size_bytes") // denormalised size for queries / billing
  photoCount            Int      @default(0) @map("photo_count") // count of <img data:...> embeds
  aestheticPositioning  String?  @map("aesthetic_positioning") // mirrored from brand_analyses for join-free queries
  dominantHex           String?  @map("dominant_hex")
  source                String   @default("manual_skill") // "manual_skill" | "pi_composer"
  metadata              Json     @default("{}")
  generatedAt           DateTime @default(now()) @map("generated_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([leadId, generatedAt(sort: Desc)])
  @@index([briefId])
  @@index([vertical, generatedAt(sort: Desc)])
  @@index([aestheticPositioning])
  @@map("demo_artefacts")
}


// ─── site QA results ─────────────────────────────────────────────────────
//
// A5 of Phase A. Per-artefact QA scores from the autumn Pi siteQaAgent
// (or any manual QA pass) — HTML validity, accessibility, contrast,
// performance, plus an overall numeric score the analytics layer can
// correlate against pitch outcomes ("do high-QA demos close better?").
//
// Soft FK to DemoArtefact.artefactId so a single artefact accumulates
// QA history (re-runs after edits). The (artefactId, ranAt DESC) index
// makes "latest QA for this artefact" a one-row lookup.

model QaResult {
  id                  String   @id @default(cuid())
  qaId                String   @unique @map("qa_id") // caller-supplied natural key
  artefactId          String   @map("artefact_id") // soft FK to demo_artefacts.artefactId
  leadId              String   @map("lead_id") // denormalised for join-free analytics
  score               Int // 0-100 overall
  passed              Boolean // typically score >= 70 but the agent owns the rule
  htmlValid           Boolean? @map("html_valid")
  htmlWarnings        Int      @default(0) @map("html_warnings")
  htmlErrors          Int      @default(0) @map("html_errors")
  accessibilityScore  Int?     @map("accessibility_score") // 0-100
  contrastScore       Int?     @map("contrast_score") // 0-100, WCAG
  performanceScore    Int?     @map("performance_score") // 0-100, weight + render
  issues              Json     @default("[]") // [{ severity, area, message, line }]
  notes               String? // free-form qualitative summary
  agentId             String?  @map("agent_id")
  agentVersion        String?  @map("agent_version") // prompt version, model id, ruleset hash
  source              String   @default("manual_skill") // "manual_skill" | "pi_qa_agent"
  metadata            Json     @default("{}")
  ranAt               DateTime @default(now()) @map("ran_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([artefactId, ranAt(sort: Desc)])
  @@index([leadId, ranAt(sort: Desc)])
  @@index([passed, score(sort: Desc)])
  @@map("qa_results")
}

// ─── lead assignment events (Tier 2 funnel timeline) ─────────────────────
//
// B1 of Phase B. Every status flip on Supabase `lead_assignments` mirrors
// here as an append-only event row so NERVE can answer funnel questions
// the closed-pitch-only `pitch_log` can't (visited→pitched conversion,
// per-SP timing, leads that got visited but never pitched).
//
// Producers: `apps/sales-dashboard/src/app/api/leads/[id]/status/route.ts`
// + `.../pitch/route.ts` cascade. Both fire-and-forget — Supabase write
// success is the source of truth, NERVE post failure must never break
// the status flip.
//
// Idempotency key: caller-supplied `eventId` = `<assignmentId>:<status>:
// <occurredAt_no_colons>`. Retries from the producer collapse into the
// same row. Multiple legitimate flips to the same status (e.g. pitched
// → visited → pitched) produce distinct rows because the timestamps differ.
//
// Status set matches AssignmentStatus across the monorepo:
// new | visited | pitched | sold | rejected (knowledge/contracts/shared-enums.md).

model LeadAssignmentEvent {
  id                    String   @id @default(cuid())
  eventId               String   @unique @map("event_id") // <assignmentId>:<status>:<iso_no_colons>
  assignmentId          String   @map("assignment_id") // Supabase lead_assignments.id (UUID)
  leadId                String   @map("lead_id") // slug
  userId                String?  @map("user_id") // sales_users.id; null for system-initiated reopens
  prevStatus            String?  @map("prev_status") // null on the very first event for an assignment
  status                String // terminal state of this transition
  transition            String // "prev_status→status" for easy GIN-style filtering
  source                String   @default("status_patch") // "status_patch" | "pitch_cascade" | "supabase_poll" | "backfill"
  rejectionReason       String?  @map("rejection_reason") // populated when status=rejected
  commissionAmountPence Int?     @map("commission_amount_pence") // populated when status=sold
  notes                 String? // free-form context from caller
  latitude              Float?
  longitude             Float?
  metadata              Json     @default("{}")
  occurredAt            DateTime @map("occurred_at") // when the flip happened (producer-supplied)
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([assignmentId, occurredAt(sort: Desc)])
  @@index([leadId, occurredAt(sort: Desc)])
  @@index([userId, occurredAt(sort: Desc)])
  @@index([status, occurredAt(sort: Desc)])
  @@index([transition])
  @@map("lead_assignment_events")
}

// ─── stripe events (Tier 2 payment timeline) ─────────────────────────────
//
// B2 of Phase B. Append-only mirror of every signature-verified Stripe
// webhook event that hits the sales-dashboard. Lets the warehouse answer
// "which closed pitches have a confirmed Stripe payment" without
// touching Stripe or Supabase — currently invisible to NERVE because the
// existing payment-confirmation signal only lives in Supabase
// lead_assignments.
//
// Producer: `apps/sales-dashboard/src/app/api/payments/webhook/route.ts`
// fans out after `constructEvent` verifies the signature, before the
// local dispatch runs. Fire-and-forget — Stripe's own retry + the
// dashboard's stripe_events idempotency table own the "did the payment
// actually settle" decision; NERVE just gets the complete log.
//
// Idempotency: caller-supplied `stripeEventId` is Stripe's `evt_...` ID,
// already globally unique. Retries (when Stripe re-fires after a 500)
// collapse onto the same row.
//
// `bodyJson` is the full event payload verbatim so future analytics can
// re-derive fields without re-fetching from Stripe. Stripe events are
// typically <50KB; JSONB column comfortably holds them.

model StripeEvent {
  id               String   @id @default(cuid())
  stripeEventId    String   @unique @map("stripe_event_id") // evt_...
  type             String // e.g. "checkout.session.completed"
  apiVersion       String?  @map("api_version")
  livemode         Boolean  @default(true) // false for test-mode events
  accountId        String?  @map("account_id") // Connect account, when applicable
  requestId        String?  @map("request_id") // originating Stripe request id
  idempotencyKey   String?  @map("idempotency_key") // Stripe-side caller idempotency
  // Denormalised business keys — extracted by the producer from event
  // metadata or the event object so analytics joins don't have to parse
  // bodyJson. All optional; not every event has all of them.
  assignmentId    String?  @map("assignment_id")
  salespersonId   String?  @map("salesperson_id")
  customerId      String?  @map("customer_id") // Stripe cus_...
  sessionId       String?  @map("session_id") // Stripe cs_...
  subscriptionId  String?  @map("subscription_id") // Stripe sub_...
  paymentIntentId String?  @map("payment_intent_id") // Stripe pi_...
  invoiceId       String?  @map("invoice_id") // Stripe in_...
  amountTotalPence Int?    @map("amount_total_pence")
  currency        String? // lowercase ISO 4217, e.g. "gbp"
  paymentStatus   String?  @map("payment_status") // "paid" | "unpaid" | "no_payment_required"
  bodyJson        Json     @map("body_json") // full event payload verbatim
  occurredAt      DateTime @map("occurred_at") // from event.created
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([type, occurredAt(sort: Desc)])
  @@index([assignmentId, occurredAt(sort: Desc)])
  @@index([customerId, occurredAt(sort: Desc)])
  @@index([sessionId])
  @@index([subscriptionId])
  @@index([paymentIntentId])
  @@map("stripe_events")
}

// ─── salesperson events (Tier 2 SP lifecycle) ────────────────────────────
//
// B3 of Phase B. Append-only mirror of every meaningful SP lifecycle
// event: signup, profile edits (self or admin), Stripe Connect setup,
// PIN reset, deactivation. Lets the warehouse answer per-SP timeline
// questions (when did Sarah sign up, when did she connect Stripe, when
// did her commission rate change) without having to read the
// sales-dashboard SQLite + Supabase split.
//
// Producers: signup handler, admin profile-edit handler, payments-
// connect handler. All fire-and-forget after the source-of-truth
// write succeeds.
//
// Idempotency: caller-supplied `eventId` = `<user_id>:<type>:
// <iso_no_colons>`. Retries collapse onto the same row.
//
// Generic shape (type + denormalised fields + JSONB metadata) matches
// the lead_assignment_events / stripe_events template — keeps the
// schema small while letting new event types land without a migration.

model SalespersonEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id") // <user_id>:<type>:<iso_no_colons>
  userId          String   @map("user_id") // sales_users.id
  type            String // "signup" | "profile_update" | "stripe_connect_created" | "stripe_connect_completed" | "pin_reset" | "deactivated" | ...
  displayName     String?  @map("display_name") // denormalised so analytics doesn't have to join
  areaPostcode    String?  @map("area_postcode") // denormalised
  stripeConnectId String?  @map("stripe_connect_id") // present on stripe_connect_* events
  source          String   @default("signup_handler") // "signup_handler" | "admin_panel" | "payments_connect" | "auth_demo" | "test"
  notes           String? // free-form context from caller
  metadata        Json     @default("{}")
  occurredAt      DateTime @map("occurred_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId, occurredAt(sort: Desc)])
  @@index([type, occurredAt(sort: Desc)])
  @@map("salesperson_events")
}
