# Admin Panel env config
#
# Copy to .env.local and fill in the secrets.

# --- Local SQLite (shared with sales-dashboard + mobile-api) ---
# Defaults to ../mission-control/mission-control.db relative to cwd.
# Set explicitly when running outside the monorepo or in tests.
# DATABASE_PATH=/abs/path/to/mission-control.db

# --- Admin auth ---
# HMAC secret used to sign admin session cookies (src/lib/admin-auth.ts).
# MUST be set in production — the default dev fallback is unsafe.
ADMIN_SECRET=admin-panel-dev-secret-change-in-production

# --- NERVE read access (F2 admin queue, 2026-05-11) ---
# Base URL of the NERVE deployment to read /api/read/* endpoints from.
NERVE_BASE_URL=https://nerve.salespatch.co.uk
# HMAC secret shared with NERVE's read endpoints. Same value as NERVE's
# OUTCOME_INGEST_SECRET — sign canonical query strings, send as
# X-Read-Signature header. Used by src/lib/nerve-read.ts.
OUTCOME_INGEST_SECRET=
